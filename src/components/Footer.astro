---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>The Learning Map of India — {year}. Independent project, not affiliated with any government body.</p>
    <p class="footer-sources">Data credited on every map. See <a href={`${base}/sources`}>sources &amp; methodology</a>.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--blackboard);
    color: var(--chalk);
    padding: 28px 0;
    margin-top: 64px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }

  .footer-inner p {
    margin: 4px 0;
    opacity: 0.85;
  }

  .footer-inner a {
    color: var(--marigold);
  }
</style>
